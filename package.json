{
  "name": "enrise-logger",
  "description": "Logger used within Enrise projects and module's",
  "version": "2.0.1",
  "author": "Team MatchMinds @ Enrise",
  "main": "index.js",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "eslint index.js test",
    "unittest": "mocha test/*.spec.js",
    "cover": "nyc mocha 'test/*.spec.js'",
    "test": "npm run lint && npm run cover"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Enrise/node-logger"
  },
  "bugs": {
    "url": "https://github.com/Enrise/node-logger/issues"
  },
  "dependencies": {
    "lodash": "^4.18.1",
    "longjohn": "^0.2.12",
    "winston": "^3.19.0"
  },
  "nyc": {
    "check-coverage": true,
    "statements": 100,
    "lines": 100,
    "branches": 100,
    "functions": 100
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "coveralls": "^3.1.1",
    "eslint": "^8.57.1",
    "eslint-config-mm": "^2.0.0",
    "mocha": "^11.7.5",
    "nyc": "^18.0.0",
    "proxyquire": "^2.1.3",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.1"
  }
}
